# Copy to .env. Both URLs default to localhost so the seed scripts will fail loudly
# until you point them at the real Elastic IPs from your Catalog/Sales CI summaries.

SALES_BASE_URL=http://YOUR_SALES_EIP
CATALOG_BASE_URL=http://YOUR_CATALOG_EIP

# After Catalog seed: reuse its clients/addresses/products (prices fetched from Catalog)
# USE_EXISTING_CATALOG=true
