# Copy to .env. Both URLs default to localhost so the seed scripts will fail loudly
# until you point them at the real Elastic IPs from your Catalog/Sales CI summaries.

SALES_BASE_URL=http://YOUR_SALES_EIP
CATALOG_BASE_URL=http://YOUR_CATALOG_EIP

# Set on Sales EC2 by CI from Core org variable SQS_QUEUE_URL (do not needed locally for pytest)
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/sales-ticket-queue

# After Catalog seed: reuse its clients/addresses/products (prices fetched from Catalog)
# USE_EXISTING_CATALOG=true

# Optional load test tuning (test_load_then_clear.py)
# LOAD_CLIENTS=15   # 150 is heavy on t2.micro + SQLite; start small
# LOAD_PRODUCTS=40
# LOAD_SALES_NOTES=80
# LOAD_LINES_PER_SALE=3
# LOAD_HTTP_ROUNDS=100
# LOAD_WORKERS=12
